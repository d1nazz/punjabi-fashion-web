# Copy to `.env.local` for local development (never commit `.env.local`).
# Use placeholders only in this file — never real secrets.

# -----------------------------------------------------------------------------
# Commerce backend (Shopify migration)
# -----------------------------------------------------------------------------
# `local-stripe` = current behavior: local catalog + Stripe Checkout (default).
# `shopify`      = opt-in only; wire Storefront in app code per SHOPIFY_MIGRATION_PLAN.md.
# Invalid / empty values fall back to local-stripe.
VITE_COMMERCE_BACKEND=local-stripe

# Shopify Storefront API (browser-safe). Domain without https://
# Production for this project uses the storefront hostname that responds to Storefront API (verify with `npm run test:shopify`).
VITE_SHOPIFY_STORE_DOMAIN=vsmauk-m2.myshopify.com
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=PASTE_STOREFRONT_ACCESS_TOKEN_HERE
VITE_SHOPIFY_API_VERSION=2025-01

# Storefront access token: intended for public Storefront API from the storefront.
# Do NOT put Shopify Admin API tokens in any VITE_* variable or client bundle.

# -----------------------------------------------------------------------------
# Stripe (current checkout — keep until Shopify checkout is verified)
# -----------------------------------------------------------------------------
# Stripe — secret key: server-side / Netlify Functions only (set in Netlify for production).
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe — webhook signing secret when you add a webhook endpoint (optional until webhooks exist).
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Canonical site URL for Stripe checkout success/cancel redirects (Netlify Functions — server-side only).
# Production: https://punjabifashion.ca
# Local Netlify dev: often http://localhost:8888
SITE_URL=https://punjabifashion.ca

# Orders / receipts (future use — not required for Checkout redirect today).
STORE_ORDER_EMAIL=info@punjabifashion.ca

# Public (safe in bundled frontend once prefixed with VITE_)
VITE_STRIPE_PUBLISHABLE_KEY=

# When running only `vite` while functions run elsewhere (e.g. `netlify dev`).
VITE_FUNCTIONS_BASE_URL=
