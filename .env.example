# Copy to `.env.local` for local development (never commit `.env.local`).
# Use placeholders only in this file — never real secrets.

# Stripe — secret key: server-side / Netlify Functions only (set in Netlify for production).
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe — webhook signing secret when you add a webhook endpoint (optional until webhooks exist).
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Canonical site URL for success/cancel redirects (e.g. `netlify dev` default port 8888).
SITE_URL=http://localhost:8888

# Orders / receipts (future use — not required for Checkout redirect today).
STORE_ORDER_EMAIL=info@punjabifashion.ca

# Public (safe in bundled frontend once prefixed with VITE_)
VITE_STRIPE_PUBLISHABLE_KEY=

# When running only `vite` while functions run elsewhere (e.g. `netlify dev`).
VITE_FUNCTIONS_BASE_URL=

# Shopify placeholders if you migrate catalog later
VITE_SHOPIFY_STORE_DOMAIN=
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=
